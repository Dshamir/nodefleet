# === CREDENTIALS (managed via Vault at /admin/credentials) ===
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# --- MongoDB ---
MONGO_INITDB_ROOT_USERNAME=<CHANGE_ME>
MONGO_INITDB_ROOT_PASSWORD=<CHANGE_ME>

# --- PostgreSQL ---
POSTGRES_USER=<CHANGE_ME>
POSTGRES_PASSWORD=<CHANGE_ME>

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=<CHANGE_ME>
RABBITMQ_DEFAULT_PASS=<CHANGE_ME>

# --- Keycloak ---
KEYCLOAK_ADMIN_PASSWORD=<CHANGE_ME>

# --- Auth ---
AUTH_CLIENT_SECRET_BACKEND=<CHANGE_ME>

# --- Internal ---
INTERNAL_SERVICES_PASSKEY=<CHANGE_ME>

# --- Email (SMTP) ---
EMAILS_SMTP_PASSWORD=<CHANGE_ME>

# --- Google reCAPTCHA ---
RECAPTCHA_SECRET_KEY=<CHANGE_ME>

# --- Swagger ---
SWAGGER_PASSWORD=<CHANGE_ME>

# --- Redis ---
REDIS_PASSWORD=<CHANGE_ME>

# --- MinIO (Object Storage) ---
MINIO_ROOT_USER=zenzers_minio
MINIO_ROOT_PASSWORD=<CHANGE_ME>

# === NON-SECRET CONFIG ===
MAIN_DOMAIN=app.zenzers4life.com
REACT_APP_RECAPTCHA_SITE_KEY=<CHANGE_ME>

# === Medical API ===
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=zenzers
KEYCLOAK_CLIENT_ID=medical-app-client
