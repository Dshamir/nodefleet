# Medical API — use Docker-mapped port (43002), not internal port (3002)
# 10.0.2.2 = Android emulator → host machine
API_URL=http://10.0.2.2:43002
TEST_DOCTOR_EMAIL=
BATTERY_UUID=00002a19-0000-1000-8000-00805f9b34fb
TEMPERATURE_UUID=00002a6e-0000-1000-8000-00805f9b34fb
HR_UUID=00002a37-0000-1000-8000-00805f9b34fb
SPO_UUID=00002a5e-0000-1000-8000-00805f9b34fb
ALERT_UUID=00002a46-0000-1000-8000-00805f9b34fb
RAW_DATA_UUID=00002a5d-0000-1000-8000-00805f9b34fb
MAC_UUID=00002a24-0000-1000-8000-00805f9b34fb
ENABLE_DEV_MODE=true
BRANCH_TEST_MODE=false
# Set to 1 to use WebSocket device emulator instead of real BLE
SIMULATION_MODE=1
# Device emulator WebSocket — Docker-mapped port (48765)
DEVICE_EMULATOR_URL=ws://10.0.2.2:48765
