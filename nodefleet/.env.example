# =============================================================================
# NodeFleet Environment Configuration
# Copy this file to .env and fill in the values before starting services.
# NEVER commit .env to git — only .env.example is tracked.
# =============================================================================

# --- Database (PostgreSQL 16) ------------------------------------------------
# Required. Connection string for the primary relational database.
DATABASE_URL=postgresql://nodefleet:nodefleet@postgres:5432/nodefleet

# --- Cache & Message Broker (Redis 7) ----------------------------------------
# Required. Used for pub/sub between web and ws-server, and rate limiting.
REDIS_URL=redis://redis:6379

# --- Object Storage (MinIO / S3-compatible) -----------------------------------
# Required. Used for media file uploads (photos, video, audio from devices).
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nodefleet-media
# Public-facing S3 URL for presigned download URLs served to browsers/devices.
S3_PUBLIC_ENDPOINT=http://localhost:50900

# --- Authentication (NextAuth v5) ---------------------------------------------
# CRITICAL: Generate a strong random secret (min 32 chars). Run:
#   openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production
# Base URL of the dashboard (used for OAuth callbacks and CSRF).
NEXTAUTH_URL=http://localhost

# --- Device Authentication ----------------------------------------------------
# CRITICAL: Must be a strong random secret. Can match NEXTAUTH_SECRET or be separate.
DEVICE_TOKEN_SECRET=change-me-in-production

# --- Stripe Billing (optional) ------------------------------------------------
# Test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# --- WebSocket Server ---------------------------------------------------------
# Internal Docker network URL (used by web app to reach ws-server).
WS_SERVER_URL=ws://ws-server:8080
# Public-facing WebSocket URL (used by browser dashboard for real-time updates).
NEXT_PUBLIC_WS_URL=ws://localhost:50080/device

# --- MQTT Broker (Mosquitto 2) ------------------------------------------------
# Internal and public MQTT broker URLs for dual-protocol telemetry.
MQTT_BROKER_URL=mqtt://mqtt:1883
MQTT_PUBLIC_URL=mqtt://localhost:51883

# --- Application URLs ---------------------------------------------------------
# Public-facing URL of the dashboard (used in emails, webhooks, device config).
NEXT_PUBLIC_URL=http://localhost:50080

# --- ngrok Tunnel (optional) --------------------------------------------------
# Provides a public HTTPS URL for development/demo. Get token at https://ngrok.com
NGROK_AUTHTOKEN=your-ngrok-authtoken-here

# --- Environment --------------------------------------------------------------
# Set to "production" for production deployments.
NODE_ENV=development
